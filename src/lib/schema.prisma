generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(uuid())
  username          String    @unique
  passwordHash      String
  fullName          String
  birthDate         DateTime?
  city              String?
  role              String    @default("USER")
  position          String?
  photos            String[]
  contacts          String?
  stats             String?
  teamId            String?
  privacyAcceptedAt DateTime?

  team         Team?         @relation(fields: [teamId], references: [id])
  captainOf    Team?         @relation("TeamCaptain")
  newsPosts    NewsPost[]
  sentMessages ChatMessage[] @relation("Sender")
  recvMessages ChatMessage[] @relation("Receiver")
  roleRequests RoleRequest[]

  supportTickets  SupportTicket[]
  supportMessages SupportMessage[]

  createdAt DateTime @default(now())
}

model Team {
  id          String   @id @default(uuid())
  name        String
  logoUrl     String?
  photos      String[]
  captainId   String?  @unique
  captain     User?    @relation("TeamCaptain", fields: [captainId], references: [id])
  stats       String?
  rating      Int      @default(1500)
  players     User[]
  homeMatches Match[]  @relation("HomeTeam")
  awayMatches Match[]  @relation("AwayTeam")
  createdAt   DateTime @default(now())
}

model Match {
  id         String       @id @default(uuid())
  homeTeamId String
  awayTeamId String
  date       DateTime
  status     String       @default("SCHEDULED")
  score      String?
  stats      String?
  venue      String?
  homeTeam   Team         @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam   Team         @relation("AwayTeam", fields: [awayTeamId], references: [id])
  events     MatchEvent[]
  createdAt  DateTime     @default(now())
}

model NewsPost {
  id          String   @id @default(uuid())
  authorId    String
  title       String
  content     String
  category    String   @default("GENERAL")
  imageUrl    String?
  matchId     String?
  isPublished Boolean  @default(false)
  author      User     @relation(fields: [authorId], references: [id])
  createdAt   DateTime @default(now())
}

model ChatMessage {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  text       String
  fileUrl    String?
  isRead     Boolean  @default(false)
  isPinned   Boolean  @default(false)
  sender     User     @relation("Sender", fields: [senderId], references: [id])
  receiver   User     @relation("Receiver", fields: [receiverId], references: [id])
  createdAt  DateTime @default(now())
}

model RoleRequest {
  id            String   @id @default(uuid())
  userId        String
  requestedRole String
  status        String   @default("PENDING")
  user          User     @relation(fields: [userId], references: [id])
  createdAt     DateTime @default(now())
}

model MatchEvent {
  id        String   @id @default(uuid())
  matchId   String
  minute    Int?
  text      String
  createdAt DateTime @default(now())
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model SupportTicket {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  subject   String
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages SupportMessage[]
}

model SupportMessage {
  id        String        @id @default(uuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User          @relation(fields: [senderId], references: [id])
  text      String
  isAdmin   Boolean       @default(false)
  createdAt DateTime      @default(now())
}

model LiveStream {
  id          String   @id @default(uuid())
  title       String   @default("Прямая трансляция")
  vkVideoUrl  String   // Ссылка на видео ВК (iframe src)
  vkGroupUrl  String   // Ссылка на группу ВК
  tgGroupUrl  String   // Ссылка на ТГ канал
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}